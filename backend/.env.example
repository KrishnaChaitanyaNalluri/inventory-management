DATABASE_URL=postgresql://postgres:password@localhost:5432/dumont_inventory

# Required. At least 24 characters. Never commit real secrets.
# Generate: openssl rand -base64 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=600

# development | production
ENVIRONMENT=development

# Comma-separated browser origins allowed to call the API (required when ENVIRONMENT=production)
# CORS_ORIGINS=https://inventory.yourdomain.com,https://www.yourdomain.com
